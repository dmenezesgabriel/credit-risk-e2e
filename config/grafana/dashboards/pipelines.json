{
    "description": "MLOps Lab — SageMaker pipeline and ETL logs via OTEL. Source: service_namespace=mlops.",
    "editable": true,
    "graphTooltip": 1,
    "links": [
        {
            "title": "Overview",
            "url": "/d/mlops-overview",
            "type": "link",
            "icon": "external link"
        },
        {
            "title": "Logs",
            "url": "/d/mlops-logs",
            "type": "link",
            "icon": "external link"
        },
        {
            "title": "Resources",
            "url": "/d/mlops-resources",
            "type": "link",
            "icon": "external link"
        }
    ],
    "panels": [
        {
            "id": 1,
            "type": "row",
            "title": "Pipeline log explorer",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            }
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "Log volume — $step",
            "description": "Log lines/s per pipeline step (OTEL source, service_namespace=mlops)",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 5,
                "w": 24,
                "x": 0,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 1,
                        "showPoints": "never"
                    }
                }
            },
            "options": {
                "legend": {
                    "calcs": [],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "sum by (service_name) (rate({service_namespace=\"mlops\", service_name=~\"$step\"}[2m]))",
                    "legendFormat": "{{service_name}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 3,
            "type": "logs",
            "title": "Logs — $step",
            "description": "Shipped via OTEL Collector → Loki. Labels: service_name, service_namespace, service_version.",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 14,
                "w": 24,
                "x": 0,
                "y": 6
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{service_namespace=\"mlops\", service_name=~\"$step\"} |= `$search`",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 10,
            "type": "row",
            "title": "Errors & warnings — pipelines",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 20
            }
        },
        {
            "id": 11,
            "type": "logs",
            "title": "Pipeline errors",
            "description": "error, exception, critical, fatal, traceback — OTEL pipeline steps only",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 0,
                "y": 21
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{service_namespace=\"mlops\", service_name=~\"$step\"} |~ `(?i)(error|exception|critical|fatal|traceback)`",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 12,
            "type": "logs",
            "title": "Pipeline warnings",
            "description": "warn / warning lines excluding errors — OTEL pipeline steps only",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 12,
                "y": 21
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{service_namespace=\"mlops\", service_name=~\"$step\"} |~ `(?i)(warn|warning)` !~ `(?i)(error|critical|fatal)`",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 20,
            "type": "row",
            "title": "Step timing",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 30
            }
        },
        {
            "id": 21,
            "type": "timeseries",
            "title": "Log activity per step — detect stalls",
            "description": "A flat line from an active step means it has stopped emitting logs. Use alongside Tempo traces for end-to-end timing.",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 7,
                "w": 24,
                "x": 0,
                "y": 31
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 5,
                        "lineWidth": 1.5,
                        "showPoints": "auto"
                    }
                }
            },
            "options": {
                "legend": {
                    "calcs": [
                        "sum",
                        "lastNotNull"
                    ],
                    "displayMode": "table",
                    "placement": "right"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "sum by (service_name) (count_over_time({service_namespace=\"mlops\"}[1m]))",
                    "legendFormat": "{{service_name}}",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "30s",
    "schemaVersion": 38,
    "tags": [
        "mlops"
    ],
    "templating": {
        "list": [
            {
                "name": "loki",
                "type": "datasource",
                "query": "loki",
                "refresh": 1,
                "label": "Loki"
            },
            {
                "name": "step",
                "type": "query",
                "label": "Pipeline step",
                "description": "Populated from service_name label set by OTEL_SERVICE_NAME in each SageMaker step",
                "datasource": {
                    "type": "loki",
                    "uid": "${loki}"
                },
                "definition": "",
                "query": {
                    "label": "service_name",
                    "stream": "{service_namespace=\"mlops\"}",
                    "type": 1
                },
                "allValue": ".+",
                "includeAll": true,
                "multi": true,
                "refresh": 2,
                "sort": 1,
                "hide": 0,
                "current": {
                    "selected": true,
                    "text": "All",
                    "value": "$__all"
                }
            },
            {
                "name": "search",
                "type": "textbox",
                "label": "Search",
                "query": "",
                "hide": 0,
                "current": {
                    "value": ""
                },
                "options": [
                    {
                        "selected": true,
                        "text": "",
                        "value": ""
                    }
                ]
            }
        ]
    },
    "time": {
        "from": "now-3h",
        "to": "now"
    },
    "timezone": "browser",
    "title": "MLOps Lab — Pipelines",
    "uid": "mlops-pipelines",
    "version": 1
}