{
    "description": "MLOps Lab — Docker service logs (Promtail). For pipeline/OTEL logs see Pipelines dashboard.",
    "editable": true,
    "graphTooltip": 1,
    "links": [
        {
            "title": "Overview",
            "url": "/d/mlops-overview",
            "type": "link",
            "icon": "external link"
        },
        {
            "title": "Pipelines",
            "url": "/d/mlops-pipelines",
            "type": "link",
            "icon": "external link"
        },
        {
            "title": "Resources",
            "url": "/d/mlops-resources",
            "type": "link",
            "icon": "external link"
        }
    ],
    "panels": [
        {
            "id": 1,
            "type": "row",
            "title": "Log explorer — docker services",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            }
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "Log volume — $container",
            "description": "Log lines/s per Docker container (Promtail source only)",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 5,
                "w": 24,
                "x": 0,
                "y": 1
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 1,
                        "showPoints": "never"
                    }
                }
            },
            "options": {
                "legend": {
                    "calcs": [],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "sum by (container) (rate({container=~\"$container\"}[2m]))",
                    "legendFormat": "{{container}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 3,
            "type": "logs",
            "title": "Logs — $container",
            "description": "Streamed from Promtail. Labels: container, service, stream, level.",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 14,
                "w": 24,
                "x": 0,
                "y": 6
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{container=~\"$container\"} |= `$search`",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 10,
            "type": "row",
            "title": "Errors & warnings — docker services",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 20
            }
        },
        {
            "id": 11,
            "type": "logs",
            "title": "Errors",
            "description": "error, exception, critical, fatal, traceback — Docker containers only",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 0,
                "y": 21
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{container=~\"$container\"} |~ `(?i)(error|exception|critical|fatal|traceback)`",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 12,
            "type": "logs",
            "title": "Warnings",
            "description": "warn / warning lines excluding errors — Docker containers only",
            "datasource": {
                "type": "loki",
                "uid": "${loki}"
            },
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 12,
                "y": 21
            },
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "loki",
                        "uid": "${loki}"
                    },
                    "expr": "{container=~\"$container\"} |~ `(?i)(warn|warning)` !~ `(?i)(error|critical|fatal)`",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "2m",
    "schemaVersion": 38,
    "tags": [
        "mlops"
    ],
    "templating": {
        "list": [
            {
                "name": "loki",
                "type": "datasource",
                "query": "loki",
                "refresh": 1,
                "label": "Loki"
            },
            {
                "name": "container",
                "type": "query",
                "label": "Container",
                "datasource": {
                    "type": "loki",
                    "uid": "${loki}"
                },
                "definition": "",
                "query": {
                    "label": "container",
                    "stream": "{}",
                    "type": 1
                },
                "allValue": ".+",
                "includeAll": true,
                "multi": true,
                "refresh": 2,
                "sort": 1,
                "hide": 0,
                "current": {
                    "selected": true,
                    "text": "All",
                    "value": "$__all"
                }
            },
            {
                "name": "search",
                "type": "textbox",
                "label": "Search",
                "query": "",
                "hide": 0,
                "current": {
                    "value": ""
                },
                "options": [
                    {
                        "selected": true,
                        "text": "",
                        "value": ""
                    }
                ]
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timezone": "browser",
    "title": "MLOps Lab — Logs",
    "uid": "mlops-logs",
    "version": 1
}