get_ipython().getoutput("uv pip install "sagemaker<3" scikit-learn pandas ")


import sagemaker
from sagemaker.sklearn.estimator import SKLearn
import os

# Define local paths
local_data_path = 'file://' + os.path.join(os.getcwd(), 'data')
local_model_path = 'file://' + os.path.join(os.getcwd(), 'model')

# Configure the Estimator for Local Mode
sklearn = SKLearn(
    entry_point='train.py',
    role='SageMakerRole', # Placeholder for local
    instance_count=1,
    instance_type='local', # CRITICAL: Sets local mode
    # framework_version='1.0-1',
    output_path=local_model_path
)

# Train locally
sklearn.fit({'train': local_data_path})

