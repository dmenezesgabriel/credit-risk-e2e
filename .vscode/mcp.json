{
    "servers": {
        "grafana": {
            "command": "uvx",
            "args": [
                "mcp-grafana",
                "--enabled-tools",
                "search,datasource,dashboard,prometheus,loki,alerting,incident,oncall,sift,asserts,pyroscope,navigation,annotations,rendering,admin,runpanelquery,cloudwatch,searchlogs"
            ],
            "env": {
                "GRAFANA_URL": "http://grafana:3000",
                "GRAFANA_USERNAME": "admin",
                "GRAFANA_PASSWORD": "admin"
            }
        },
        "duckdb": {
            "command": "uvx",
            "args": [
                "mcp-server-motherduck",
                "--db-path",
                ":memory:",
                "--read-write",
                "--allow-switch-databases"
            ]
        },
        "s3": {
            "command": "uv",
            "args": [
                "run",
                "mcp/s3_mcp_server/server.py"
            ],
            "env": {
                "AWS_REGION": "us-east-1",
                "AWS_ACCESS_KEY_ID": "test",
                "AWS_SECRET_ACCESS_KEY": "test",
                "AWS_ENDPOINT_URL": "http://localstack:4566",
                "S3_MAX_BUCKETS": "5"
            }
        }
        // "playwright": {
        //     "command": "npx",
        //     "args": [
        //         "-y",
        //         "@microsoft/mcp-server-playwright"
        //     ]
        // },
        // "chrome-devtools": {
        //     "command": "npx",
        //     "args": [
        //         "-y",
        //         "chrome-devtools-mcp@latest"
        //     ]
        // }
    }
}