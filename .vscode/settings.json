{
    "terminal.integrated.defaultProfile.linux": "zsh",
    "python.defaultInterpreterPath": "/usr/local/bin/python",
    "breadcrumbs.enabled": false,
    "update.enableWindowsBackgroundUpdates": false,
    "typescript.surveys.enabled": false,
    "workbench.enableExperiments": false,
    "workbench.editor.enablePreview": false,
    // Telemetry
    "telemetry.editStats.details.enabled": false,
    "telemetry.editStats.enabled": false,
    "telemetry.editStats.showDecorations": false,
    "telemetry.editStats.showStatusBar": false,
    "telemetry.feedback.enabled": false,
    "redhat.telemetry.enabled": false,
    //  Window
    "window.menuBarVisibility": "compact",
    "window.zoomLevel": 0,
    "window.titleBarStyle": "custom",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "window.title": "${folderName}/${activeEditorShort}",
    "symbols.hidesExplorerArrows": false,
    // Fonts
    "editor.fontFamily": "'JetBrains Mono', monospace",
    "editor.fontSize": 14,
    "editor.lineHeight": 1.8,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    //  Editor
    "editor.codeLens": false,
    "editor.accessibilitySupport": "off",
    "editor.copyWithSyntaxHighlighting": false,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "editor.rulers": [
        80,
        120
    ],
    "editor.renderLineHighlight": "gutter",
    "editor.fontLigatures": true,
    "editor.semanticHighlighting.enabled": false,
    "editor.minimap.enabled": false,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "editor.suggestSelection": "first",
    "editor.guides.bracketPairs": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.guides.bracketPairsHorizontal": "active",
    "editor.suggestOnTriggerCharacters": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.quickSuggestions": {
        "comments": "on",
        "strings": "on",
        "other": "on"
    },
    "editor.autoClosingBrackets": "always",
    // Startup
    "workbench.startupEditor": "newUntitledFile",
    "update.showReleaseNotes": false,
    // Explorer
    "explorer.compactFolders": false,
    "explorer.sortOrder": "foldersNestsFiles",
    "workbench.activityBar.location": "default",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
        ".env": ".env*",
        ".prettierrc": ".prettier*",
        "eslint.config.mjs": ".eslint*"
    },
    //  Search
    "search.exclude": {
        "**/node_modules": true,
        "**/env": true,
        "**/venv": true
    },
    // Tabs
    "workbench.editor.labelFormat": "short",
    // "workbench.editor.showTabs": "none",
    "window.customTitleBarVisibility": "auto",
    // Terminal
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        },
        "zsh": {
            "path": "zsh",
            "icon": "terminal-bash"
        }
    },
    "terminal.integrated.automationProfile.linux": {
        "path": "tmux",
        "args": [
            "new-session",
            "-A",
            "-s",
            "vscode:${workspaceFolder}"
        ]
    },
    // Extensions
    "extensions.ignoreRecommendations": true,
    // Files
    "files.trimTrailingWhitespace": true,
    // Emmet
    "emmet.triggerExpansionOnTab": true,
    "emmet.excludeLanguages": [],
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
        "markdown": "html"
    },
    "emmet.syntaxProfiles": {
        "javascript": "jsx",
        "mdx": "jsx"
    },
    // Security
    "security.workspace.trust.untrustedFiles": "newWindow",
    // HTML
    "html.format.wrapAttributes": "force-expand-multiline",
    "html.format.wrapLineLength": 80,
    "html.autoClosingTags": true,
    //  Python
    "black-formatter.args": [
        "--line-length",
        "79"
    ],
    // Languages
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true
    },
    "[sql]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[yaml]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.autoIndent": "advanced"
    },
    "[yml]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": false,
        "editor.autoIndent": "advanced"
    },
    "[dockercompose]": {
        "editor.autoIndent": "advanced"
    },
    "[html]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[xml]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
    },
    "[javascript]": {
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "prettier.printWidth": 80,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "prettier.bracketSameLine": false,
        "prettier.bracketSpacing": true,
    },
    "[typescript]": {
        "editor.detectIndentation": false,
        // Editor
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[terraform][terraform-vars]": {
        "editor.defaultFormatter": "hashicorp.terraform",
        "editor.formatOnSave": false,
        "editor.codeActionsOnSave": {
            "source.formatAll.terraform": "explicit"
        }
    },
    // Spelling
    "cSpell.language": ",pt,pt_BR,en_US",
    "cSpell.enabled": true,
    "cSpell.enabledFileTypes": {
        "css": true,
        "handlebars": true,
        "html": true,
        "javascript": true,
        "javascriptreact": true,
        "json": true,
        "jsonc": true,
        "markdown": true,
        "md": true,
        "plaintext": true,
        "python": true,
        "scss": true,
        "text": true,
        "typescript": true,
        "typescriptreact": true,
        "yaml": true,
        "yml": true,
        "ipynb": true,
        "jupyter": true
    },
    "cSpell.enabledSchemes": {
        "file:": true,
        "gist:": true,
        "sftp:": true,
        "untitled:": true,
        "ipynb": true
    },
    // AWS Toolkit — LocalStack endpoints
    "aws.dev.endpoints": {
        "s3": "http://localhost:4566",
        "sqs": "http://localhost:4566",
        "sns": "http://localhost:4566",
        "dynamodb": "http://localhost:4566",
        "lambda": "http://localhost:4566",
        "iam": "http://localhost:4566",
        "cloudwatch": "http://localhost:4566",
        "ec2": "http://localhost:4566",
        "kinesis": "http://localhost:4566",
        "secretsmanager": "http://localhost:4566",
        "ssm": "http://localhost:4566",
        "stepfunctions": "http://localhost:4566",
        "eventbridge": "http://localhost:4566",
        "apigateway": "http://localhost:4566",
        "logs": "http://localhost:4566",
        "sts": "http://localhost:4566"
    },
    // Prettier
    "prettier.printWidth": 80,
    // Telemetry
    "telemetry.telemetryLevel": "off",
    // Notebook
    "notebook.diff.overviewRuler": true,
    "notebook.formatOnSave.enabled": true,
    "chat.agent.enabled": true,
    "github.copilot.nextEditSuggestions.enabled": false,
    "python.analysis.typeCheckingMode": "strict",
    "workbench.colorTheme": "Catppuccin Macchiato",
    "workbench.iconTheme": "catppuccin-macchiato"
}